# ---- Database ----
# Local dev (host): postgres running via docker-compose, exposed on 5432
DATABASE_URL="postgresql://meals:meals@localhost:5432/meals?schema=public"
# Inside docker network the api uses host "postgres" instead of "localhost":
# DATABASE_URL="postgresql://meals:meals@postgres:5432/meals?schema=public"

POSTGRES_USER=meals
POSTGRES_PASSWORD=meals
POSTGRES_DB=meals

# ---- API ----
API_PORT=3001
API_HOST=0.0.0.0
# Comma-separated origins allowed by CORS (the web app).
CORS_ORIGIN="http://localhost:5173"

# ---- Receipt/flyer OCR ----
# Provider: "local" (self-hosted vision model, fully offline) or "claude".
OCR_PROVIDER="local"

# Local provider — any OpenAI-compatible server running a vision model.
# Ollama (default): http://localhost:11434/v1   ·   run: ollama pull qwen2.5vl:3b
# vLLM (optional):  http://localhost:8000/v1     (see docs/local-ocr.md)
# From inside Docker, point at the host: http://host.docker.internal:11434/v1
OCR_LOCAL_BASE_URL="http://localhost:11434/v1"
OCR_LOCAL_MODEL="qwen2.5vl:3b"
OCR_LOCAL_API_KEY=""

# Claude provider (only used when OCR_PROVIDER=claude) — SERVER SIDE ONLY, never in the web bundle.
ANTHROPIC_API_KEY=""
OCR_MODEL="claude-sonnet-5"
OCR_ESCALATION_MODEL="claude-opus-4-8"

# ---- Object storage (receipt images) ----
# MVP: local disk volume. Later: MinIO/S3.
STORAGE_DIR="./storage"

# ---- Web (build-time, safe to expose) ----
VITE_API_BASE_URL="http://localhost:3001"
