# ---- Database ----
# Local dev (host): postgres running via docker-compose, exposed on 5432
DATABASE_URL="postgresql://meals:meals@localhost:5432/meals?schema=public"
# Inside docker network the api uses host "postgres" instead of "localhost":
# DATABASE_URL="postgresql://meals:meals@postgres:5432/meals?schema=public"

POSTGRES_USER=meals
POSTGRES_PASSWORD=meals
POSTGRES_DB=meals

# ---- API ----
API_PORT=3001
API_HOST=0.0.0.0
# Comma-separated origins allowed by CORS (the web app).
CORS_ORIGIN="http://localhost:5173"

# ---- Receipt/flyer OCR ----
# Provider: "local" (self-hosted vision model, fully offline) or "claude".
OCR_PROVIDER="local"

# Local provider — any OpenAI-compatible server running a vision model.
# Ollama (default): http://localhost:11434/v1   ·   run: ollama pull qwen2.5vl:3b
# vLLM (optional):  http://localhost:8000/v1     (see docs/local-ocr.md)
# From inside Docker, point at the host: http://host.docker.internal:11434/v1
# Host-run scripts (link-ingredients, categorize, coupons) use this:
OCR_LOCAL_BASE_URL="http://localhost:11434/v1"
# The API *container* reaches host Ollama here (compose default; override only if needed):
# OCR_LLM_URL_DOCKER="http://host.docker.internal:11434/v1"
OCR_LOCAL_MODEL="qwen2.5vl:3b"
OCR_LOCAL_API_KEY=""

# Claude provider (only used when OCR_PROVIDER=claude) — SERVER SIDE ONLY, never in the web bundle.
ANTHROPIC_API_KEY=""
OCR_MODEL="claude-sonnet-5"
OCR_ESCALATION_MODEL="claude-opus-4-8"

# ---- Kroger / Fry's integration (developer.kroger.com) ----
# Create an app in the Kroger developer portal; register the redirect URI below there too.
KROGER_CLIENT_ID=""
KROGER_CLIENT_SECRET=""
KROGER_REDIRECT_URI="http://localhost:8090/api/integrations/kroger/callback"
# Apps created in the NEW Kroger portal use the CE host:
KROGER_API_BASE="https://api-ce.kroger.com/v1"

# ---- Cloudflare Access (Zero Trust) ----
# When BOTH are set, a request carrying a verified Cf-Access-Jwt-Assertion header is logged in
# as that email (invited emails Access lets through are auto-provisioned as role=base). Requests
# without the header (LAN/localhost, not through the tunnel) still use the local admin fallback.
#   TEAM_DOMAIN: Zero Trust dashboard → Settings → Custom Pages / your team name → "<team>.cloudflareaccess.com"
#   AUD:         Access → Applications → (app.pantrezy.com) → Overview → "Application Audience (AUD) Tag"
CF_ACCESS_TEAM_DOMAIN=""
CF_ACCESS_AUD=""

# ---- Object storage (receipt images) ----
# MVP: local disk volume. Later: MinIO/S3.
STORAGE_DIR="./storage"

# ---- Web (build-time, safe to expose) ----
# Docker build default is "/api" (same-origin nginx proxy — works from phones on the LAN).
# For `pnpm dev` (vite on :5173) the client falls back to http://localhost:3001.
VITE_API_BASE_URL="/api"

# ---- Docker host ports (override if a port is already taken on your machine) ----
# web is published on 8090 by default because :8080 collides on many machines.
WEB_PORT=8090
API_HOST_PORT=3001
POSTGRES_HOST_PORT=5432
