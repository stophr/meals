// Meals — data model.
//
// Central modeling split (see plan "Data model — the crux"):
//   CanonicalItem   = store-agnostic concept ("2% milk, 1 gal"). Recipes, inventory,
//                     and shopping lists reference this.
//   ProviderProduct = one specific store's listing/SKU. Prices attach here.
//   CanonicalItem 1—* ProviderProduct ; the link is established by the matcher + human review.
//
// Unit normalization: every quantity is stored twice — as entered (value + Unit) and
// normalized to a base unit per dimension (MASS->g, VOLUME->ml, COUNT->each). Price
// comparisons and the optimizer run purely on base units.
//
// Everything is scoped by householdId so multi-user (Phase 3) is additive, not a rewrite.

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UnitDimension {
  MASS
  VOLUME
  COUNT
}

enum Unit {
  // mass
  MG
  G
  KG
  OZ
  LB
  // volume
  ML
  L
  FLOZ
  CUP
  TBSP
  TSP
  // count
  EACH
  PACK
  BUNCH
  CAN
  BOTTLE
}

enum PriceSource {
  MANUAL
  OCR
  SCRAPE
}

// Where a Product field-group (description vs nutrition) was sourced from. Precedence between
// them is configured independently in code (see apps/api/src/lib/productCorpus.ts).
enum ProductSource {
  KROGER // Fry's / any Kroger banner — authoritative for description/brand/size
  STORE // another store integration
  USDA // USDA FoodData Central — authoritative for nutrition
  OFF // Open Food Facts
  UPCITEMDB // UPCitemdb — last-resort description + images
  IFPS // produce PLU code -> commodity name
  MANUAL // user-entered / legacy
}

enum JobType {
  OCR_RECEIPT
  OCR_FLYER
  SCRAPE
}

enum JobStatus {
  QUEUED
  RUNNING
  NEEDS_REVIEW
  DONE
  FAILED
}

enum Complexity {
  EASY
  MEDIUM
  HARD
}

// ---------------------------------------------------------------------------
// Household / users
// ---------------------------------------------------------------------------

// The tenant. "Org" in the UI; the data-scope key (householdId) throughout. Each org holds
// its own inventory, providers, prices, meal plans, shopping lists, substitutions, and users.
model Household {
  id       String  @id @default(cuid())
  name     String
  slug     String? @unique
  homeLat  Float?
  homeLng  Float?
  currency String  @default("USD")
  // Lambda: money value of one shopping minute, used by the time-vs-savings optimizer.
  timeValuePerMinute Decimal @default("0.25") @db.Decimal(10, 4)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  providers      Provider[]
  recipes        Recipe[]
  mealRules      MealRule[]
  inventory      InventoryLot[]
  mealPlans      MealPlan[]
  shoppingLists  ShoppingList[]
  jobs           IngestionJob[]
  integrationTokens IntegrationToken[]
  krogerCoupons  KrogerCoupon[]
  substitutions  IngredientSubstitution[]
  brandPreferences BrandPreference[]
  recipeFavorites RecipeFavorite[]
  magicLinks     MagicLink[]
}

// Row exists now so FKs are stable; auth is deferred to Phase 3.
// A member of an org. Roles: base (view the meal lineup), sous_chef (everything but managing
// users), chef (everything incl. inviting/removing users). isAppAdmin (the app owner) can
// invite new orgs. The first user to join an org becomes chef.
model User {
  id          String    @id @default(cuid())
  householdId String
  household   Household  @relation(fields: [householdId], references: [id], onDelete: Cascade)
  email       String    @unique
  displayName String?
  role        String    @default("chef") // base | sous_chef | chef
  isAppAdmin  Boolean   @default(false)
  createdAt   DateTime  @default(now())

  sessions    Session[]
  dietProfile DietProfile?

  @@index([householdId])
}

// ---- Diet profiles (feature #16). The macro splits + goal deltas are PROVISIONAL until a
// registered dietitian reviews them (DietStyle.rdReviewed). Calorie math is standard
// (Mifflin–St Jeor). Guidance only — not medical advice. ----

enum BiologicalSex {
  FEMALE
  MALE
}

enum ActivityLevel {
  SEDENTARY // little/no exercise
  LIGHT // 1–3 days/week
  MODERATE // 3–5 days/week
  ACTIVE // 6–7 days/week
  VERY_ACTIVE // hard daily exercise / physical job
}

enum DietGoal {
  LOSE
  MAINTAIN
  GAIN
}

// A selectable eating regimen expressed as a calorie-macro split. Seeded provisionally; the RD
// edits the percentages/notes and flips rdReviewed once vetted.
model DietStyle {
  id          String  @id @default(cuid())
  key         String  @unique // "balanced", "high_protein", …
  name        String
  description String
  proteinPct  Int // % of calories from protein (proteinPct + carbPct + fatPct should = 100)
  carbPct     Int
  fatPct      Int
  sortOrder   Int     @default(0)
  rdReviewed  Boolean @default(false) // true once the dietitian signs off on the numbers
  notes       String? // RD guidance / caveats

  profiles  DietProfile[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// One per user (age/activity/goal are personal). Targets are cached, recomputed on every save.
model DietProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  birthYear     Int?
  sex           BiologicalSex?
  heightCm      Decimal?       @db.Decimal(6, 2)
  weightKg      Decimal?       @db.Decimal(6, 2)
  activityLevel ActivityLevel?
  goal          DietGoal       @default(MAINTAIN)

  dietStyleId String?
  dietStyle   DietStyle? @relation(fields: [dietStyleId], references: [id], onDelete: SetNull)

  // Cached targets (null until enough inputs). Recomputed server-side on save.
  targetCalories Int?
  proteinG       Int?
  carbG          Int?
  fatG           Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Passwordless auth. A magic link is emailed; following it consumes the link and mints a
// Session (device cache, ~3 months). Also used for org invites (carries householdId + role).
// EMAIL DELIVERY IS STUBBED until the pantrezy.com domain is live — see docs/multi-tenancy.md.
model MagicLink {
  id           String     @id @default(cuid())
  email        String
  householdId  String?    // invite into this org; null = plain sign-in to an existing account
  household    Household? @relation(fields: [householdId], references: [id], onDelete: Cascade)
  intendedRole String?    // role granted when an invite is first accepted
  token        String     @unique
  expiresAt    DateTime
  consumedAt   DateTime?
  createdAt    DateTime   @default(now())

  @@index([email])
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token      String   @unique
  device     String?
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
  expiresAt  DateTime // device cache window (3 months to start)

  @@index([userId])
}

// A tenant-scoped ingredient swap. recipeId null = an org-global rule (e.g. always use
// Avocado Oil for Olive Oil), remembered until reverted/changed; recipeId set = only that
// recipe. Applied in coverage, costing, list-building, and recipe display.
model IngredientSubstitution {
  id                  String        @id @default(cuid())
  householdId         String
  household           Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  fromCanonicalItemId String
  fromItem            CanonicalItem @relation("SubFrom", fields: [fromCanonicalItemId], references: [id], onDelete: Cascade)
  toCanonicalItemId   String
  toItem              CanonicalItem @relation("SubTo", fields: [toCanonicalItemId], references: [id], onDelete: Cascade)
  recipeId            String?
  recipe              Recipe?       @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  createdAt           DateTime      @default(now())

  @@unique([householdId, fromCanonicalItemId, recipeId])
  @@index([householdId])
}

// Per-org preferred brand for an ingredient — biases shopping-list product choice. A swap while
// shopping upserts this (always-save). Fallback is cheapest-available when the brand isn't stocked.
model BrandPreference {
  id              String        @id @default(cuid())
  householdId     String
  household       Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  canonicalItemId String
  canonicalItem   CanonicalItem @relation(fields: [canonicalItemId], references: [id], onDelete: Cascade)
  brand           String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([householdId, canonicalItemId])
  @@index([householdId])
}

// ---------------------------------------------------------------------------
// Catalog: canonical items <-> per-provider products
// ---------------------------------------------------------------------------

// GLOBAL, store-agnostic ingredient dictionary shared by every org. Recipes (also shared) link
// to these; each org's inventory, provider products, prices, aliases keep their own householdId
// but reference the same global items — so a shared recipe resolves to items any org can stock
// and price at its own store.
model CanonicalItem {
  id String @id @default(cuid())

  name     String
  brand    String?
  category String?

  // Default pack presentation (informational; concrete packs live on ProviderProduct).
  packSize Decimal? @db.Decimal(12, 4)
  packUnit Unit?

  // Base-unit facts used for price-per-unit math.
  baseUnit      Unit?
  baseDimension UnitDimension?

  // Bridge for a future recipe<->purchase density conversion (out of MVP scope).
  recipeUnit   Unit?
  purchaseUnit Unit?

  // Density bridge: reconcile weight <-> volume <-> count for THIS item, so a "5 lb sugar
  // bag" nets against "2 cups sugar". Grams is the pivot; nulls fall back to same-dimension.
  gramsPerMl   Decimal? @db.Decimal(10, 4) // density (mass per volume)
  gramsPerEach Decimal? @db.Decimal(10, 4) // typical mass of one unit (1 egg ≈ 50 g)

  // Always-on-hand staples (water, tap water, ice): assumed in stock, so they never
  // count as "missing" for cook-from-pantry and are skipped when building shopping lists.
  assumeStocked Boolean @default(false)

  // Normalized dedup key (lowercased, unit/pack stripped) — used by the matcher.
  normKey String

  // Representative product for this ingredient — used for recipe nutrition when the item isn't
  // currently stocked (recipes reference the generic ingredient, not a specific container).
  referenceProductId String?
  referenceProduct   Product? @relation("ItemReferenceProduct", fields: [referenceProductId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products          ProviderProduct[]
  upcProducts       Product[]          @relation("ItemProducts")
  recipeIngredients RecipeIngredient[]
  inventory         InventoryLot[]
  shoppingListItems ShoppingListItem[]
  ingredientAliases IngredientAlias[]
  substitutionsFrom IngredientSubstitution[] @relation("SubFrom")
  substitutionsTo   IngredientSubstitution[] @relation("SubTo")
  brandPreferences  BrandPreference[]

  @@index([normKey])
  @@index([name])
  @@index([referenceProductId])
}

// Maps a messy ingredient name ("packed dark brown sugar", "pinch of sugar") to the buyable
// canonical item, so refining/consolidating the corpus never breaks recipes and future
// imports resolve to the right root instead of spawning yet another variant.
// GLOBAL name->item vocabulary (shared with the global canonical dictionary).
model IngredientAlias {
  id String @id @default(cuid())

  rawName         String        @unique // normalized (lowercased) alias
  canonicalItemId String
  canonicalItem   CanonicalItem @relation(fields: [canonicalItemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([canonicalItemId])
}

// A physical store location whose product corpus (listings + prices) is SHARED by every
// household that shops there. Keyed by chain+locationId ("kroger:66000693"), so two households
// linked to the same Fry's pull from one corpus; a never-seen location mints a new one.
model StoreLocation {
  id          String @id @default(cuid())
  chain       String // "kroger" for integrated stores; "manual" for hand-entered ones
  locationKey String @unique // "kroger:<locationId>" or "provider:<providerId>" (manual, per-provider)

  name    String
  address String?
  lat     Float?
  lng     Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  providers Provider[]
  products  ProviderProduct[]
  aliases   ProductAlias[]
}

model Provider {
  id          String     @id @default(cuid())
  householdId String
  household   Household   @relation(fields: [householdId], references: [id], onDelete: Cascade)

  // The shared store-location corpus this household's provider draws from.
  storeLocationId String?
  storeLocation   StoreLocation? @relation(fields: [storeLocationId], references: [id], onDelete: SetNull)

  name    String
  type    String  @default("grocery")
  address String?
  lat     Float?
  lng     Float?

  // Round-trip visit cost inputs for the optimizer.
  travelMinutes Int?
  travelKm      Float?

  // Store-chain integration config, e.g. {"type":"kroger","locationId":"70100135"}.
  integration Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([householdId])
  @@index([storeLocationId])
}

// Digital coupons fetched from the user's Fry's/Kroger account (via the host-side
// Playwright script). Clipping is approval-gated: proposed -> approved (user) -> clipped.
model KrogerCoupon {
  id          String    @id // Kroger coupon id
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  description String
  brand       String?
  valueText   String? // "Save $1.00", "2 for $5"…
  value       Decimal?  @db.Decimal(10, 2) // parsed $ off when determinable
  expiresAt   DateTime?
  upcs        String[]  @default([])

  // Match against our catalog (UPC-first vs synced Fry's products).
  matchedProductId String?
  matchedItemName  String?

  status    String    @default("proposed") // proposed | approved | clipped | dismissed | failed
  fetchedAt DateTime  @default(now())
  clippedAt DateTime?

  @@index([householdId, status])
}

// OAuth tokens for store integrations (e.g. the Kroger user token that authorizes cart
// pushes). One row per household+provider-kind.
model IntegrationToken {
  id          String    @id @default(cuid())
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  kind         String // "kroger"
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  scopes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([householdId, kind])
}

model ProviderProduct {
  id String @id @default(cuid())

  // Products belong to the shared store-location corpus, not one household's provider.
  storeLocationId String
  storeLocation   StoreLocation @relation(fields: [storeLocationId], references: [id], onDelete: Cascade)

  // Null until matched to a canonical item (matcher + human review).
  canonicalItemId String?
  canonicalItem   CanonicalItem? @relation(fields: [canonicalItemId], references: [id], onDelete: SetNull)

  rawName  String
  brand    String?
  sizeText String?

  // Concrete pack for this listing + its base-unit expansion.
  packSize     Decimal? @db.Decimal(12, 4)
  packUnit     Unit?
  baseQuantity Decimal? @db.Decimal(14, 4)

  upc String?
  plu String?
  sku String?
  url String?
  imageUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  prices  PriceObservation[]
  aliases ProductAlias[]

  @@unique([storeLocationId, upc])
  @@index([storeLocationId])
  @@index([canonicalItemId])
  @@index([upc])
}

// Local UPC corpus: a store-agnostic branded PRODUCT (a "container" of an ingredient), keyed by
// UPC. Built up + refreshed from the most accurate source first — Fry's/Kroger for
// description/brand/size, USDA/OFF for nutrition — with the two field-groups sourced by
// INDEPENDENT precedence. ProviderProduct (store price) references the same UPC; InventoryLot
// points here as the physical container on the shelf. Everything except water is a Product.
model Product {
  id  String @id @default(cuid())
  upc String @unique

  canonicalItemId String
  canonicalItem   CanonicalItem @relation("ItemProducts", fields: [canonicalItemId], references: [id], onDelete: Cascade)

  // Description group (Fry's > other stores > OFF).
  description String
  brand       String?
  sizeText    String? // as printed, e.g. "32 fl oz"
  packSize     Decimal? @db.Decimal(12, 4)
  packUnit     Unit?
  baseQuantity Decimal? @db.Decimal(14, 4) // net contents in base units
  imageUrl     String?
  imageCached  Boolean @default(false) // medium image downloaded to PRODUCT_IMAGE_DIR/<upc>.jpg
  descriptionSource    ProductSource @default(MANUAL)
  descriptionUpdatedAt DateTime      @default(now())

  // Nutrition group, per serving (USDA > OFF). Nulls = unknown.
  servingText         String? // e.g. "2 tbsp (30 ml)"
  servingBaseQuantity Decimal? @db.Decimal(14, 4) // one serving in base units
  servingDimension    UnitDimension? // dimension of servingBaseQuantity (MASS/VOLUME/COUNT)
  servingsPerContainer Decimal? @db.Decimal(10, 2)
  calories  Decimal? @db.Decimal(10, 2)
  proteinG  Decimal? @db.Decimal(10, 2)
  carbsG    Decimal? @db.Decimal(10, 2)
  sugarG    Decimal? @db.Decimal(10, 2)
  fiberG    Decimal? @db.Decimal(10, 2)
  fatG      Decimal? @db.Decimal(10, 2)
  satFatG   Decimal? @db.Decimal(10, 2)
  sodiumMg  Decimal? @db.Decimal(10, 2)
  nutritionSource    ProductSource?
  nutritionUpdatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventory     InventoryLot[]
  referenceFor  CanonicalItem[] @relation("ItemReferenceProduct")

  @@index([canonicalItemId])
}

// Learned rawName -> product mapping, persisted from every human review decision so the
// next identical line auto-matches.
model ProductAlias {
  id String @id @default(cuid())

  storeLocationId String
  storeLocation   StoreLocation @relation(fields: [storeLocationId], references: [id], onDelete: Cascade)

  normalizedRawName String
  providerProductId String
  providerProduct   ProviderProduct @relation(fields: [providerProductId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([storeLocationId, normalizedRawName])
  @@index([providerProductId])
}

model PriceObservation {
  id                String          @id @default(cuid())
  providerProductId String
  providerProduct   ProviderProduct @relation(fields: [providerProductId], references: [id], onDelete: Cascade)

  price            Decimal  @db.Decimal(12, 2)
  pricePerBaseUnit Decimal? @db.Decimal(14, 6)
  currency         String   @default("USD")

  isDeal        Boolean  @default(false)
  dealType      String?
  multiBuyQty   Int?
  multiBuyPrice Decimal? @db.Decimal(12, 2)
  regularPrice  Decimal? @db.Decimal(12, 2)

  validFrom  DateTime  @default(now())
  validTo    DateTime?
  observedAt DateTime  @default(now())

  source     PriceSource
  confidence Float?
  rawText    String?

  @@index([providerProductId, validFrom])
  @@index([providerProductId, validTo])
}

// ---------------------------------------------------------------------------
// Recipes
// ---------------------------------------------------------------------------

model Recipe {
  id          String    @id @default(cuid())
  // householdId = the org that added it (owner). Shared recipes form a GLOBAL directory
  // visible to every org; a tenant's own private recipes have isShared=false.
  householdId String
  household   Household  @relation(fields: [householdId], references: [id], onDelete: Cascade)
  isShared    Boolean   @default(true)

  name         String
  servings     Int      @default(1)
  instructions String?
  sourceUrl    String?
  prepMinutes  Int?

  // Catalog metadata (populated by ingestion; editable by the user).
  sourceName String? // e.g. "TheMealDB", "allrecipes.com"
  externalId String? // provider-specific id for dedup (e.g. TheMealDB idMeal)
  imageUrl   String?
  cuisine    String? // "ethnicity" facet, e.g. Italian, Thai
  category   String? // e.g. Dessert, Breakfast, Pasta
  tags       String[] @default([])
  complexity Complexity?

  // External stars (from the source site) vs local signals.
  externalRating      Float? // 0..5
  externalRatingCount Int?
  timesCooked         Int       @default(0)
  lastCookedAt        DateTime?

  // Denormalized cost estimate from real store prices (recompute-costs script).
  // Proportional costing: amount used ÷ pack size × pack price, promo-aware.
  estCostTotal      Decimal?  @db.Decimal(10, 2)
  estCostPerServing Decimal?  @db.Decimal(10, 2)
  costCoverage      Float? // fraction of required ingredients that were priceable (0..1)
  promoIngredients  Int? // how many priced ingredients are currently on promo
  costUpdatedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ingredients   RecipeIngredient[]
  mealPlanEntries MealPlanEntry[]
  mealRules       MealRule[]
  substitutions   IngredientSubstitution[]
  favorites       RecipeFavorite[]

  @@index([householdId])
  @@index([householdId, cuisine])
  @@index([householdId, category])
  @@index([isShared])
  // Unique per household so bulk imports can dedup with skip semantics (NULLs exempt).
  @@unique([householdId, externalId])
}

// Per-org favorite. Favorites are org-scoped even though recipes are shared globally.
model RecipeFavorite {
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  recipeId    String
  recipe      Recipe    @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@id([householdId, recipeId])
  @@index([recipeId])
}

// Global cache of a recipe page's raw schema.org JSON-LD node, keyed by external id. Decouples
// FETCH (slow, network, rate-limited) from PARSE (fast, local): the crawler stores raw once,
// and any parser fix is applied by re-parsing the stored raw — no re-crawl. Source-level (not
// per-org).
model RecipeRawFetch {
  id         String   @id @default(cuid())
  externalId String   @unique // e.g. foodcom:184564
  sourceUrl  String
  raw        Json // the schema.org Recipe JSON-LD node
  fetchedAt  DateTime @default(now())
}

model RecipeIngredient {
  id       String @id @default(cuid())
  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  // Null + freeText until mapped to a canonical item.
  canonicalItemId String?
  canonicalItem   CanonicalItem? @relation(fields: [canonicalItemId], references: [id], onDelete: SetNull)
  freeText        String?

  quantity     Decimal  @db.Decimal(12, 4)
  unit         Unit
  baseQuantity Decimal? @db.Decimal(14, 4)
  prepNote     String?
  optional     Boolean  @default(false)

  @@index([recipeId])
  @@index([canonicalItemId])
}

// ---------------------------------------------------------------------------
// Inventory (lot-based for expiry / FIFO)
// ---------------------------------------------------------------------------

model InventoryLot {
  id          String    @id @default(cuid())
  householdId String
  household   Household  @relation(fields: [householdId], references: [id], onDelete: Cascade)

  canonicalItemId String
  canonicalItem   CanonicalItem @relation(fields: [canonicalItemId], references: [id], onDelete: Cascade)

  // The specific container (UPC product) on the shelf, when known (e.g. scanned). Nutrition +
  // brand/size come from here; the canonical item stays the ingredient recipes reference.
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  quantity     Decimal  @db.Decimal(12, 4)
  unit         Unit
  baseQuantity Decimal  @db.Decimal(14, 4)

  // What's physically on the shelf: brand is informational (the canonical item stays
  // store-agnostic for recipe/coverage math).
  brand       String?
  location    String?
  purchasedAt DateTime  @default(now())
  expiresAt   DateTime?

  createdAt DateTime @default(now())

  @@index([householdId, canonicalItemId])
  @@index([householdId, expiresAt])
  @@index([productId])
}

// ---------------------------------------------------------------------------
// Meal plan -> shopping list
// ---------------------------------------------------------------------------

model MealPlan {
  id          String    @id @default(cuid())
  householdId String
  household   Household  @relation(fields: [householdId], references: [id], onDelete: Cascade)

  name      String?
  startDate DateTime
  endDate   DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries       MealPlanEntry[]
  shoppingLists ShoppingList[]

  @@index([householdId])
}

model MealPlanEntry {
  id         String   @id @default(cuid())
  mealPlanId String
  mealPlan   MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)

  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  // Null = staged/unassigned: the recipe sits in the plan without a day yet.
  date            DateTime?
  slot            String    @default("dinner")
  servingsPlanned Int       @default(1)

  // Set when a shopping list bought for this meal; cleared automatically if that list
  // is deleted. Locked entries reject edits.
  lockedByListId String?
  lockedByList   ShoppingList? @relation("LockedEntries", fields: [lockedByListId], references: [id], onDelete: SetNull)

  @@index([mealPlanId])
  @@index([recipeId])
  @@index([lockedByListId])
}

// Recurring meals: "tacos every Tuesday", "pizza once a week on a random day",
// "pot roast monthly on the 15th". Materialized into plan entries per date range.
enum RepeatKind {
  RANDOM_WEEKLY
  RANDOM_MONTHLY
  DAILY
  WEEKLY
  MONTHLY
}

model MealRule {
  id          String    @id @default(cuid())
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  recipeId    String
  recipe      Recipe    @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  kind       RepeatKind
  weekday    Int? // 0=Sun..6=Sat, for WEEKLY
  dayOfMonth Int? // 1..31 (clamped to month length), for MONTHLY
  slot       String     @default("dinner")
  servings   Int?
  active     Boolean    @default(true)
  createdAt  DateTime   @default(now())

  @@index([householdId, active])
}

model ShoppingList {
  id          String    @id @default(cuid())
  householdId String
  household   Household  @relation(fields: [householdId], references: [id], onDelete: Cascade)

  mealPlanId String?
  mealPlan   MealPlan? @relation(fields: [mealPlanId], references: [id], onDelete: SetNull)

  name   String?
  status String @default("draft") // draft | optimized | shopping | done

  // Shopping horizon this list bought for. Days inside [coverageStart, coverageEnd] are
  // LOCKED for meal edits while this list exists; deleting the list unlocks them.
  coverageStart DateTime?
  coverageEnd   DateTime?

  // Cached optimizer result (chosen option + alternatives) for offline/in-store use.
  optimizationResult Json?

  // Archived lists drop out of the active Shop view. Auto-set once today passes coverageEnd.
  archivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items         ShoppingListItem[]
  lockedEntries MealPlanEntry[]    @relation("LockedEntries")

  @@index([householdId])
  @@index([mealPlanId])
}

model ShoppingListItem {
  id             String       @id @default(cuid())
  shoppingListId String
  shoppingList   ShoppingList @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)

  canonicalItemId String
  canonicalItem   CanonicalItem @relation(fields: [canonicalItemId], references: [id], onDelete: Cascade)

  quantityNeeded     Decimal @db.Decimal(12, 4)
  unit               Unit
  baseQuantityNeeded Decimal @db.Decimal(14, 4)

  // Filled by the optimizer / user overrides.
  assignedProviderId String?
  chosenProductId    String?
  estimatedPrice     Decimal? @db.Decimal(12, 2)

  // How this item picks its store: cheapest total (default) vs cheapest per-unit (worth it
  // for shelf-stable staples bought in bulk). Set globally or per item.
  priceMode String @default("total") // total | unit

  status String @default("pending") // pending | bought | skipped

  @@index([shoppingListId])
  @@index([canonicalItemId])
}

// ---------------------------------------------------------------------------
// Ingestion jobs (OCR / scrape) + staging lines before confirmation
// ---------------------------------------------------------------------------

model IngestionJob {
  id          String    @id @default(cuid())
  householdId String
  household   Household  @relation(fields: [householdId], references: [id], onDelete: Cascade)

  type       JobType
  status     JobStatus @default(QUEUED)
  providerId String?
  inputRef   String? // storage path / URL of the source image or page
  result     Json?
  error      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines ExtractionLine[]

  @@index([householdId, status])
}

model ExtractionLine {
  id    String       @id @default(cuid())
  jobId String
  job   IngestionJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  rawName    String
  quantity   Decimal? @db.Decimal(12, 4)
  unit       String?
  unitPrice  Decimal? @db.Decimal(12, 2)
  totalPrice Decimal? @db.Decimal(12, 2)

  // Matcher suggestion; confirmed/edited in the review UI.
  matchProductId  String?
  matchConfidence Float?
  status          String  @default("pending") // pending | confirmed | rejected | new

  @@index([jobId])
}
